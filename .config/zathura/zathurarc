# zathurarc
set selection-clipboard clipboard
# colors
set font "monospace 16"

include "zathura-gruvbox-dark-hard"

set synctex-editor-command "vim -v --not-a-term -T dumb -c \"VimtexInverseSearch %{line}:%{column} '%{input}'\""

# set adjust-open width
# set print_command "/home/dmarti/bin/printer.sh %s"
set show-scrollbars false
set scroll-wrap false

# use sqlite as bookmarks database backend
set database sqlite

set guioptions ''

# key bindings
unmap r
unmap R
unmap f

map <PageUp> navigate previous
map <PageDown> navigate next
map , navigate previous
map . navigate next
map <C-q> quit
map r reload
map R rotate
map F follow
map P print
map T toggle_inputbar
map _ mark_evaluate
map <C-Button4> zoom in
map <C-Button5> zoom out
