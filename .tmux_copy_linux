bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi V send-keys -X rectangle-toggle
bind -T copy-mode-vi Y send-keys -X copy-end-of-line # ^1
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xsel -i -p | xsel -i -b"
unbind -T copy-mode-vi Enter
bind -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "tee >(xsel -i -p) | xsel -i -b"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "tee >(xsel -i -p) | xsel -i -b"
