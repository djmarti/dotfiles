SET BrRed Esc + "[1;31m"
SET BrGrn Esc + "[1;32m"
SET BrYlw Esc + "[1;33m"
SET BrBlu Esc + "[1;34m"
SET BrMag Esc + "[1;35m"
SET BrCyn Esc + "[1;36m"
SET BrWht Esc + "[1;37m"

BANNER [Blu]%"Reminders for %w, %d%s %m %t%o:[Nrm]%
